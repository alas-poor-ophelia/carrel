{
  "name": "carrel",
  "version": "1.3.0",
  "description": "Carrel: a novel way to view your notes — an Obsidian plugin",
  "type": "module",
  "scripts": {
    "build:css": "sass scss/main.scss styles.css --no-source-map --no-charset",
    "build:css:watch": "sass scss/main.scss styles.css --no-source-map --no-charset --watch",
    "build": "bun run build:css && bun esbuild.config.mjs production",
    "build:dev": "bun run build:css && bun esbuild.config.mjs",
    "build:prod": "bun run build:css && bun esbuild.config.mjs production",
    "build:watch": "bun esbuild.config.mjs --watch",
    "deploy": "bun run build:dev && bun scripts/deploy.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "bun run typecheck && bun run lint",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "version": "bun version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "@preact/signals": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-plugin-obsidianmd": "0.3.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "node-html-parser": "^7.1.0",
    "obsidian": "^1.11.0",
    "preact": "^10.26.0",
    "sass": "^1.83.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "rollup": "^4.62.0",
    "vite": "^6.4.3",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15"
  },
  "license": "MIT"
}
